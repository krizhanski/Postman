        {
          "name": "Car expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Статус 200: Витрату створено\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Пробіг відповідає  значенню\", function () {",
                  "    const requestMileage = pm.environment.get(\"currentMileage\");",
                  "    const responseData = pm.response.json().data;",
                  "    ",
                  "    pm.expect(responseData.mileage).to.eql(Number(requestMileage));",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let lastMileage = Number(pm.environment.get(\"lastMileage\")) || 100;",
                  "",
                  "// 2. Додаємо до нього довільне число",
                  "let newMileage = lastMileage + 50;",
                  "",
                  "// 3. Зберігаємо нове значення назад у середовище під назвою 'currentMileage'",
                  "pm.environment.set(\"currentMileage\", newMileage);",
                  "",
                  "// 4. Оновлюємо 'lastMileage'",
                  "pm.environment.set(\"lastMileage\", newMileage);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
