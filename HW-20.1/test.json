          "name": "Creating a unique user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let requestBody = JSON.parse(pm.request.body.raw);",
                  "pm.environment.set(\"currentPassword\", requestBody.password);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Унікальний ID для імейлу",
                  "let uniqueId = Date.now();",
                  "pm.environment.set(\"userEmail\", \"serhii.qa\" + uniqueId + \"@test.com\");",
                  "",
                  "// Генеруємо випадкове 5-значне число для пароля",
                  "let randomNum = Math.floor(Math.random() * 90000) + 10000;",
                  "",
                  "// Формуємо пароль ",
                  "pm.environment.set(\"userPassword\", \"Pass\" + randomNum);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Serhii\",\n  \"lastName\": \"Test\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"repeatPassword\": \"{{userPassword}}\"\n}\n",
