        {
          "name": "Change Password",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// 1. Беремо поточний пароль зі змінної оточення (яка вже була встановлена на етапі реєстрації)",
                  "let currentPassword = pm.environment.get(\"currentPassword\");",
                  "",
                  "// Запобіжник: якщо змінної немає, виводимо помилку в консоль",
                  "if (!currentPassword) {",
                  "    console.error(\"Помилка: Змінна currentPassword порожня! Переконайся, що попередній запит (Signup) зберіг її.\");",
                  "}",
                  "",
                  "// 2. Генеруємо новий пароль для цього конкретного прогону в Runner",
                  "let randomNum = Math.floor(Math.random() * 10000);",
                  "let newPassword = \"NewPass\" + randomNum + \"!\";",
                  "",
                  "// 3. Зберігаємо новий пароль у змінну, щоб Postman міг підставити його в тіло запиту:",
                  "// { \"oldPassword\": \"{{currentPassword}}\", \"password\": \"{{newPassword}}\", \"repeatPassword\": \"{{newPassword}}\" }",
                  "pm.environment.set(\"newPassword\", newPassword);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 - Password changed\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Якщо сервер прийняв новий пароль",
                  "if (pm.response.code === 200) {",
                  "    let justSetPassword = pm.environment.get(\"newPassword\");",
                  "    ",
                  "    // ОНОВЛЮЄМО змінну currentPassword. ",
                  "    // Тепер для всіх наступних запитів у Runner цей новий пароль вважатиметься \"поточним\"",
                  "    pm.environment.set(\"currentPassword\", justSetPassword);",
                  "    ",
                  "    // Прибираємо за собою тимчасову змінну",
                  "    pm.environment.unset(\"newPassword\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"{{currentPassword}}\",\n  \"password\": \"{{newPassword}}\",\n  \"repeatPassword\": \"{{newPassword}}\"\n}",
