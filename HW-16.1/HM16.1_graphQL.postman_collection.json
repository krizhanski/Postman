      "name": "Cities",
      "item": [
        {
          "name": "GetAllCities",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "// Helper function to generate a random integer between min and max",
                  "function getRandomNumber(min, max) {",
                  "    return Math.floor(Math.random() * (max - min + 1)) + min;",
                  "}",
                  "// Initialize an empty array to store the selected city IDs",
                  "let arrayWithId = [];",
                  "// Function to select a specific number of random city IDs from the provided array",
                  "function getRandomIds(array, count) {",
                  "    for (let i = 0; i < count; i++) {",
                  "        arrayWithId.push(array[getRandomNumber(0, array.length - 1)].id);",
                  "    }",
                  "}",
                  "// Execute the function to get 4 random IDs and save them to collection variables",
                  "getRandomIds(jsonData.data.getAllCities, 4);",
                  "pm.collectionVariables.set(\"arrayWithId\", arrayWithId);",
                  "// Function to calculate the average 'square' (area) value of all cities in the array",
                  "function getAverageValue(arr) {",
                  "    let max = 0; ",
                  "    for (let i = 0; i < arr.length; i++) {",
                  "        max = max + arr[i].square;",
                  "    }",
                  "    return max / arr.length;",
                  "}",
                  "// Calculate the average square and save it to a collection variable for later use",
                  "pm.collectionVariables.set(\"squareAvg\", getAverageValue(jsonData.data.getAllCities));",
                  "// Postman test to ensure the response contains at least one city ",
                  "pm.test(\"Check lenght of array\", function () {",
                  "    pm.expect(jsonData.data.getAllCities.length).to.be.greaterThan(0);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query {\n  getAllCities {\n    id\n    name\n    square\n  }\n}",
                "variables": ""
              }
            },
            "url": {
              "raw": "{{url}}",
              "host": [
                "{{url}}"
              ]
            }
          },
          "response": []
