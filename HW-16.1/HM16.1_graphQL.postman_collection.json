        {
          "name": "GetCitiesByRangeId",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response body as a JSON object",
                  "let jsonData = pm.response.json();",
                  "",
                  "// Calculate the expected count of cities within the inclusive range (max - min + 1)",
                  "let cityRange = pm.collectionVariables.get(\"maxId\") - pm.collectionVariables.get(\"minId\") + 1;",
                  "",
                  "// Postman test to verify that the returned array matches the calculated range size",
                  "pm.test(\"Check city range\", function () {",
                  "    // Assert that the length of the returned array equals the expected range count",
                  "    pm.expect(jsonData.data.getCityByRangeId.length).to.eql(cityRange);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Option 1: Calculate the range boundaries",
                  "let arrayWithId = pm.collectionVariables.get(\"arrayWithId\");",
                  "",
                  "// Use the spread operator (...) with Math.min to find the smallest ID in the array",
                  "let minId = Math.min(...arrayWithId);",
                  "// Save the minimum ID to a collection variable for use in the GraphQL variables",
                  "pm.collectionVariables.set(\"minId\", minId);",
                  "",
                  "// Use the spread operator with Math.max to find the largest ID in the array",
                  "let maxId = Math.max(...arrayWithId);",
                  "// Save the maximum ID to a collection variable",
                  "pm.collectionVariables.set(\"maxId\", maxId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query($minId: Int! = 1, $maxId: Int! = 22) {\n  getCityByRangeId(filter: {minId: $minId, maxId: $maxId}) {\n    id\n    name\n    square\n  }\n}",
                "variables": "{\n  \"minId\": {{minId}},\n  \"maxId\": {{maxId}}\n}"
              }
            },
            "url": {
              "raw": "{{url}}",
              "host": [
                "{{url}}"
              ]
            }
          },
          "response": []
