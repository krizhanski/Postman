                  "// Test to verify the number of returned objects (aliases)",
                  "pm.test(\"Check length of object\", function () {",
                  "    // Count the number of keys in the 'data' object (should be 4)",
                  "    pm.expect(Object.keys(jsonData.data).length).to.eql(4);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Retrieve the first ID from the saved array and store it as a separate collection variable",
                  "let id0 = pm.collectionVariables.get(\"arrayWithId\")[0];",
                  "pm.collectionVariables.set(\"id0\", id0);",
                  "let id1 = pm.collectionVariables.get(\"arrayWithId\")[1];",
                  "pm.collectionVariables.set(\"id1\", id1);",
                  "let id2 = pm.collectionVariables.get(\"arrayWithId\")[2];",
                  "pm.collectionVariables.set(\"id2\", id2);",
                  "let id3 = pm.collectionVariables.get(\"arrayWithId\")[3];",
                  "pm.collectionVariables.set(\"id3\", id3);"
                ],
                "type": "text/javascript",
                "packages": {},
