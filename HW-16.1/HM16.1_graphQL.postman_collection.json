          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetCities($id0: ID!, $id1: ID!, $id2: ID!, $id3: ID!) {\n  city1: getCityById(id: $id0) {\n    ...CityDetails\n  }\n  city2: getCityById(id: $id1) {\n    ...CityDetails\n  }\n  city3: getCityById(id: $id2) {\n    ...CityDetails\n  }\n  city4: getCityById(id: $id3) {\n    ...CityDetails\n  }\n}\n\nfragment CityDetails on CityAbstract {\n  id\n  cityName: name  \n  square\n}",
                "variables": "{\n  \"id0\": \"{{id0}}\",\n  \"id1\": \"{{id1}}\",\n  \"id2\": \"{{id2}}\",\n  \"id3\": \"{{id3}}\"\n}"
              }
