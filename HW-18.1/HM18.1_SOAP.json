  "item": [
    {
      "name": "ISBN13",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Check status code (must be 200 OK)",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Check response time (less than 2000ms)",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// 3. Check for the presence of the Content-Type header",
              "pm.test(\"Content-Type header is present\", function () {",
              "    pm.response.to.have.header(\"Content-Type\");",
              "});",
              "",
              "// 4. Check Content-Type header value (must contain text/xml)",
              "pm.test(\"Content-Type is text/xml\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/xml\");",
              "});",
              "",
              "// 5. Basic check: whether the raw response text contains the required tag",
              "pm.test(\"Body contains IsValidISBN13Result tag\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"IsValidISBN13Result\");",
              "});",
              "",
              "",
              "// --- Convert XML to JSON for deeper body checks ---",
              "var jsonObject = xml2Json(responseBody);",
              "",
              "// 6. Check for the presence of the main soap:Envelope tag",
              "pm.test(\"SOAP Envelope is present\", function () {",
              "    pm.expect(jsonObject).to.have.property(\"soap:Envelope\");",
              "});",
              "",
              "// 7. Check for the presence of soap:Body inside Envelope",
              "pm.test(\"SOAP Body is present\", function () {",
              "    pm.expect(jsonObject[\"soap:Envelope\"]).to.have.property(\"soap:Body\");",
              "});",
              "",
              "// 8. Check for the presence of m:IsValidISBN13Response",
              "pm.test(\"IsValidISBN13Response is present\", function () {",
              "    pm.expect(jsonObject[\"soap:Envelope\"][\"soap:Body\"]).to.have.property(\"m:IsValidISBN13Response\");",
              "});",
              "",
              "// 9. Check the specific result (whether the ISBN is indeed valid = true)",
              "pm.test(\"ISBN13 is valid (Result is true)\", function () {",
              "    var result = jsonObject[\"soap:Envelope\"][\"soap:Body\"][\"m:IsValidISBN13Response\"][\"m:IsValidISBN13Result\"];",
              "    pm.expect(result).to.eql(\"true\"); // After converting XML, values become strings",
              "});",
              "",
              "// 10. Check for the correct namespace (xmlns:m)",
              "pm.test(\"Namespace is correct\", function () {",
              "    var responseNode = jsonObject[\"soap:Envelope\"][\"soap:Body\"][\"m:IsValidISBN13Response\"];",
              "    // Postman's xml2Json stores tag attributes in the \"$\" property",
              "    pm.expect(responseNode[\"$\"][\"xmlns:m\"]).to.eql(\"http://webservices.daehosting.com/ISBN\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disabledSystemHeaders": {
          "host": true,
          "content-type": true
        }
      },
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "text/xml; charset=utf-8",
            "type": "text"
          },
          {
            "key": "Host",
            "value": "webservices.daehosting.com",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\">\n  <soap:Body>\n    <IsValidISBN13 xmlns=\"http://webservices.daehosting.com/ISBN\">\n      <sISBN>978-1-4612-9090-2</sISBN>\n    </IsValidISBN13>\n  </soap:Body>\n</soap:Envelope>",
          "options": {
            "raw": {
              "language": "xml"
            }
          }
        },
        "url": {
          "raw": "http://webservices.daehosting.com/services/isbnservice.wso",
          "protocol": "http",
          "host": [
            "webservices",
            "daehosting",
            "com"
          ],
          "path": [
            "services",
            "isbnservice.wso"
          ]
        }
      },
      "response": []
    },
